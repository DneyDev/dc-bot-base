# =============================================
# Configuração do bot — preencha antes de rodar
# =============================================

# Token do bot (Discord Developer Portal > Bot > Token)
DISCORD_TOKEN=

# ID da aplicação (Discord Developer Portal > General Information)
CLIENT_ID=

# Chave de licença — gerada pelo desenvolvedor
BOT_LICENSE_KEY=

# Segredo de licença — gerado pelo desenvolvedor
MASTER_SECRET=

# Módulos ativos (separados por vírgula)
# Opções: rpg, moderation, games
MODULES=rpg,moderation

# MongoDB
MONGO_URI=
MONGO_DB=
